#!/usr/bin/env bash
# WS1 Validator (T3) — per-tool base-pair stats, plus cross-tool comparison when >1 tool.
#
# Contract (the Nextflow VALIDATE process depends on it):
#     ws1-validate --annotations <a.cif> [<b.cif> ...] --out <prefix>
#       => writes <prefix>.json and <prefix>.tsv
#
# This CLI owns the gate: it always reports per-tool stats, and runs the cross-tool
# comparison (compare_basepairs.py) only when more than one tool is given.
set -euo pipefail
lib="$(dirname "$(command -v ws1-validate)")"

annotations=()
out=
while [ $# -gt 0 ]; do
    case "$1" in
        --annotations) shift; while [ $# -gt 0 ] && [ "$1" != "--out" ]; do annotations+=("$1"); shift; done ;;
        --out)         out=$2; shift 2 ;;
        *) echo "ws1-validate: unknown argument '$1'" >&2; exit 2 ;;
    esac
done
[ -n "$out" ] && [ "${#annotations[@]}" -gt 0 ] || { echo "usage: ws1-validate --annotations <cif...> --out <prefix>" >&2; exit 2; }

if [ "${#annotations[@]}" -gt 1 ]; then
    python3 "$lib/compare_basepairs.py" --annotations "${annotations[@]}" --out "$out" --compare
else
    echo "[ws1-validate] only one tool — per-tool stats only, cross-tool comparison skipped" >&2
    python3 "$lib/compare_basepairs.py" --annotations "${annotations[@]}" --out "$out"
fi
