#!/usr/bin/env python3
"""WS1 skeleton STUB — Parser (T2).

Contract (do not change; the Nextflow PARSE process depends on it):
    ws1-parse --tool <name> --raw <tool output> --structure <structure.cif> --out <out.cif>

Parser team: replace the body with the real conversion to a standardized
base-pairing mmCIF (NDB extended _ndb_base_pair_list / _ndb_base_pair_annotation
categories). A reference implementation already exists in read_write_mmcif/.
This stub reads the JSON annotation envelope and writes a minimal, valid mmCIF.
"""
import argparse
import json
import sys
from pathlib import Path

LOOP_HEADER = """loop_
_ndb_base_pair_list.base_pair_id
_ndb_base_pair_list.PDB_model_number
_ndb_base_pair_list.auth_asym_id_1
_ndb_base_pair_list.auth_seq_id_1
_ndb_base_pair_list.comp_id_1
_ndb_base_pair_list.auth_asym_id_2
_ndb_base_pair_list.auth_seq_id_2
_ndb_base_pair_list.comp_id_2
"""


def main():
    ap = argparse.ArgumentParser(description="WS1 parser (stub)")
    ap.add_argument("--tool", required=True)
    ap.add_argument("--raw", required=True)
    ap.add_argument("--structure", required=True)
    ap.add_argument("--out", required=True)
    args = ap.parse_args()

    pairs = []
    try:
        pairs = json.loads(Path(args.raw).read_text()).get("base_pairs", [])
    except Exception as exc:  # stub: tolerate anything
        print(f"[ws1-parse:{args.tool}] could not read {args.raw}: {exc}", file=sys.stderr)

    out = [f"data_{args.tool}_basepairs\n"]
    if pairs:
        out.append(LOOP_HEADER)
        for i, _pair in enumerate(pairs, 1):
            out.append(f"{i} 1 . . . . . .\n")  # placeholder row scheme
    else:
        out.append("# (stub) no base pairs annotated — parser team fills this in\n")
    out.append("#\n")

    Path(args.out).write_text("".join(out))
    print(f"[ws1-parse:{args.tool}] {args.raw} -> {args.out} ({len(pairs)} pairs)", file=sys.stderr)


if __name__ == "__main__":
    main()
