#!/usr/bin/env bash
# WS1 Parser (T2) — tool-native annotation output -> standardized base-pairing mmCIF.
#
# Contract (the Nextflow PARSE process depends on it):
#     ws1-parse --tool <name> --raw <file> --structure <cif> --out <out.cif>
#       fr3d     : raw TSV -> JSON -> NDB base-pairing mmCIF
#       rnapolis : raw JSON -> NDB base-pairing mmCIF
#
# The conversion logic lives next to this CLI in bin/ (run with the conda python3).
set -euo pipefail

tool= ; raw= ; structure= ; out=
while [ $# -gt 0 ]; do
    case "$1" in
        --tool)      tool=$2;      shift 2 ;;
        --raw)       raw=$2;       shift 2 ;;
        --structure) structure=$2; shift 2 ;;
        --out)       out=$2;       shift 2 ;;
        *) echo "ws1-parse: unknown argument '$1'" >&2; exit 2 ;;
    esac
done
[ -n "$tool" ] && [ -n "$raw" ] && [ -n "$structure" ] && [ -n "$out" ] || {
    echo "usage: ws1-parse --tool <name> --raw <file> --structure <cif> --out <out.cif>" >&2; exit 2; }

lib="$(dirname "$(command -v ws1-parse)")"
case "$tool" in
    fr3d)
        python3 "$lib/fr3d_basepair_to_json.py" "$raw" basepairs.json
        python3 "$lib/json_fr3d_mmcif.py" basepairs.json "$structure" "$out" >/dev/null
        ;;
    rnapolis)
        python3 "$lib/json_rnapolis_mmcif.py" "$raw" "$structure" "$out" >/dev/null
        ;;
    *)
        echo "ws1-parse: no parser wired for tool '$tool'" >&2; exit 2 ;;
esac
echo "[ws1-parse:$tool] $raw -> $out" >&2
