#!/usr/bin/env bash
# WS1 Annotator (T2) — run a base-pair annotator on the mmCIF.
#
# Contract (the Nextflow ANNOTATE process depends on it):
#     ws1-annotate --tool <name> --structure <cif> --out <prefix> --src <annotations_tools dir>
#       fr3d     -> writes <prefix>.txt   (FR3D basepair TSV)
#       rnapolis -> writes <prefix>.json  (RNApolis annotator JSON)
#
# Each tool runs from its pinned submodule under --src (via PYTHONPATH), so the
# exact annotator commit is what executes — the conda envs supply only deps, not
# the tool itself. --src is passed by the module so this CLI stays location-agnostic.
set -euo pipefail

tool= ; structure= ; out= ; src=
while [ $# -gt 0 ]; do
    case "$1" in
        --tool)      tool=$2;      shift 2 ;;
        --structure) structure=$2; shift 2 ;;
        --out)       out=$2;       shift 2 ;;
        --src)       src=$2;       shift 2 ;;
        *) echo "ws1-annotate: unknown argument '$1'" >&2; exit 2 ;;
    esac
done
[ -n "$tool" ] && [ -n "$structure" ] && [ -n "$out" ] && [ -n "$src" ] || {
    echo "usage: ws1-annotate --tool <name> --structure <cif> --out <prefix> --src <dir>" >&2; exit 2; }

case "$tool" in
    fr3d)
        fr3d_src="$src/fr3d-python"
        export PYTHONPATH="$fr3d_src:${PYTHONPATH:-}"
        python "$fr3d_src/fr3d/classifiers/NA_pairwise_interactions.py" -i . "$structure" -o "$out"
        mv "$(find . -name '*_basepair.txt' | head -n 1)" "$out.txt"
        ;;
    rnapolis)
        rnapolis_src="$src/rnapolis-py/src"
        export PYTHONPATH="$rnapolis_src:${PYTHONPATH:-}"
        python "$rnapolis_src/rnapolis/annotator.py" "$structure" -j "$out.json" -e
        ;;
    *)
        echo "ws1-annotate: no annotator wired for tool '$tool'" >&2; exit 2 ;;
esac
echo "[ws1-annotate:$tool] $structure -> $out" >&2
