// WS1 annotation & validation workflow skeleton.
// The colored task modules (T1 conversion, T2 core, T3 exploration) plug into
// this skeleton through the stage CLIs in bin/ and the env files in envs/.

manifest {
    name            = 'ws1-annotation-validation'
    description      = 'WS1: reproducible nucleic-acid annotation & validation workflow skeleton'
    author          = 'Simon Crouzet'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
}

params {
    input      = null              // structure: .pdb or .cif  (required)
    converter  = 'maxit'           // T1 converter: maxit (default) | gemmi (deprecated)
    annotators = 'fr3d,rnapolis'   // comma-separated annotator names (one per env/<name>.yml)
    outdir     = 'results'
}

// Every run uses conda — Nextflow builds the per-process envs from envs/*.yml,
// including maxit (bioconda::maxit) for T1 conversion. No Docker needed.
conda.enabled = true

// `-profile test`: identical run, on the bundled 9CFN input.
profiles {
    test {
        params.input      = "${projectDir}/../../data/9CFN/9CFN_clean.cif"
        params.annotators = 'fr3d,rnapolis'
    }
}
