// WS1 annotation & validation workflow skeleton.
// The colored task modules (T1 conversion, T2 core, T3 exploration) plug into
// this skeleton through the stage CLIs in bin/ and the env files in envs/.

manifest {
    name            = 'ws1-annotation-validation'
    description      = 'WS1: reproducible nucleic-acid annotation & validation workflow skeleton'
    author          = 'Simon Crouzet'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
}

params {
    input      = null              // structure: .pdb or .cif  (required)
    annotators = 'fr3d'            // comma-separated annotator names (one per env/<name>.yml)
    outdir     = 'results'
}

// Software environments are attached per process and selected by profile.
// Default = conda. mamba is an opt-in speed profile; docker/singularity for
// reproducible / HPC runs; test = fast, no env management, bundled 9CFN input.
profiles {
    standard    { conda.enabled = true }                                          // default
    conda       { conda.enabled = true }
    mamba       { conda.enabled = true; conda.useMamba = true }
    docker      { docker.enabled = true }
    singularity { singularity.enabled = true; singularity.autoMounts = true }
    test {
        conda.enabled    = false
        params.input      = "${projectDir}/../../data/9CFN/9CFN_clean.cif"
        params.annotators = 'fr3d,rnapolis'
    }
}
